# ===========================================
# CONFIGURAÇÃO DO ZAPIER (WEBHOOK)
# ===========================================
# Cole aqui a URL do webhook que você criou no Zapier
# Esta é a ÚNICA variável necessária para o site funcionar!
VITE_ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXXXX/XXXXXXX/

# Como obter esta URL:
# 1. Acesse zapier.com e crie uma conta (gratuita - 100 tarefas/mês)
# 2. Clique em "Create Zap"
# 3. Em "Trigger": escolha "Webhooks by Zapier" → "Catch Hook"
# 4. Copie a URL do webhook fornecida pelo Zapier
# 5. Cole a URL acima (substitua o exemplo XXXXXXX)
# 6. Teste o webhook clicando em "Test trigger" no Zapier
# 7. Em "Action": escolha "Reev" e configure para criar/atualizar lead
# 8. Mapeie os campos recebidos para os campos do Reev:
#    - nome → Nome
#    - sobrenome → Sobrenome  
#    - email → Email
#    - phone → Telefone
#    - company → Empresa
#    - cidade → Cidade
#    - uf → Estado
#    - tipo_usuario → Tipo de Usuário
#    - perfil_profissional → Perfil

# ===========================================
# OPCIONAL: Configuração antiga do Supabase
# (Não é mais necessário se usar Zapier direto)
# ===========================================
# VITE_SUPABASE_URL=your_supabase_url_here
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

